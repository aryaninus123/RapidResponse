# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rapidrespond

# Auth
JWT_SECRET_KEY=your-secret-key-here

# Google Cloud (required for translation service)
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=credentials/google-cloud-credentials.json

# Apify (required for real-time data collection)
APIFY_API_TOKEN=your-apify-token

# Redis (optional — caching/real-time features)
REDIS_URL=redis://localhost:6379

# Server
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000
